%{
#include "parser.tab.h"
#include <stdio.h>
#include <stdlib.h>
%}

%%
"SET"     { return SET; }
"ADD"     { return ADD; }
"SUB"     { return SUB; }
"PRINT"   { return PRINT; }

[0-9]+    { yylval.num = atoi(yytext); return NUMBER; }
[a-zA-Z]  { yylval.num = yytext[0]; return ID; }

"="       { return '=';}

[ \t\n]+  ;   // ignore spaces

.         { printf("Invalid character: %s\n", yytext); }

%%

int yywrap() {
    return 1;
}

